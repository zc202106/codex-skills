  "repro": {
    "mode": "ui-automation",
    "scenarioName": "GroundNode 默认启动观察",
    "steps": [
      {
        "type": "launch",
        "description": "启动 Ruiyan_UAV 主程序并观察控制台输出"
      },
      {
        "type": "wait",
        "seconds": 20,
        "description": "等待界面初始化和首轮日志输出"
      }
    ],
    "uiAutomation": {
      "windowTitlePattern": "地面站控制系统",
      "actions": [
        {
          "type": "wait_window",
          "windowTitlePattern": "地面站控制系统",
          "description": "等待主窗口出现",
