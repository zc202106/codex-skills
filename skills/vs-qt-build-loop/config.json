    "buildDirectory": "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\x64\\Release",
    "outputDirectory": "D:\\Video\\150\\GroundNode\\x64\\Release\\Ruiyan_UAV",
    "configuration": "Release",
    "platform": "x64",
    "msbuildTargets": [
      "Build"
    ],
    "msbuildProperties": {
      "Configuration": "Release",
      "Platform": "x64",
      "QtInstall": "C:\\Qt\\Qt5.11.0\\5.11.0\\msvc2017_64",
      "QtMsBuild": "D:\\Video\\150\\GroundNode\\QtMsBuild",
      "TrackFileAccess": "false",
      "ForceRebuild": "true"
    },
    "qmakeArguments": [],
    "jomArguments": [
      "/J",
      "8"
    ]
  },
  "translations": {
    "enabled": true,
    "tsSearchRoot": "D:\\Video\\150\\GroundNode\\Ruiyan_UAV",
    "tsPatterns": [
      "*.ts"
    ],
    "lupdateTargets": [
      "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\Ruiyan_UAV.pro"
    ],
    "qmOutputDirectory": "D:\\Video\\150\\GroundNode\\Ruiyan_UAV",
    "copyTargets": [
      "D:\\Video\\150\\GroundNode\\Ruiyan_UAV",
      "D:\\Video\\150\\GroundNode\\x64\\Release\\Ruiyan_UAV"
    ]
  },
  "uiDiagnostics": {
    "enabled": true,
    "logFunction": "qDebug",
    "markerPrefix": "[CODEX_UI]",
    "defaultTargets": [
      "D:\\Video\\150\\GroundNode\\Ruiyan_UAV"
    ],
    "keywordRules": [
      {
        "id": "login-flow",
        "keywords": [
          "登录",
          "login"
        ],
        "preferredFiles": [
          "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\Login.cpp",
          "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\Login.h"
        ]
      },
      {
        "id": "main-window",
        "keywords": [
          "主界面",
          "主窗口",
          "main window"
        ],
        "preferredFiles": [
          "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\MainWindows.cpp",
          "D:\\Video\\150\\GroundNode\\Ruiyan_UAV\\ControlPage.cpp"
        ]
      }
    ]
  },
  "runtime": {
    "enabled": true,
    "workingDirectory": "D:\\Video\\150\\GroundNode\\x64\\Release\\Ruiyan_UAV",
    "executablePath": "D:\\Video\\150\\GroundNode\\x64\\Release\\Ruiyan_UAV\\Ruiyan_UAV.exe",
    "arguments": [],
    "startupTimeoutSeconds": 15,
    "captureDurationSeconds": 20,
    "stopAfterCapture": true,
    "treatAliveAfterCaptureAsSuccess": true,
    "allowNonZeroExitCode": false,
    "errorRules": [
      {
        "id": "qt-platform-plugin-missing",
        "pattern": "Could not find the Qt platform plugin",
        "category": "qt-platform-plugin-missing",
        "autoFix": ""
      },
      {
        "id": "translation-load-failed",
        "pattern": "installTranslator failed",
        "category": "translation-load-failed",
        "autoFix": "refresh-translations"
      },
      {
        "id": "fatal-runtime",
        "pattern": "ASSERT|Unhandled exception|Segmentation fault|Access violation",
        "category": "fatal-runtime",
        "autoFix": ""
      }
    ]
  },
  "repro": {
    "enabled": true,
    "mode": "manual-assisted",
    "scenarioName": "默认启动观察",
    "steps": [
      {
        "type": "launch",
        "description": "启动 Ruiyan_UAV 主程序并观察控制台输出"
      },
      {
        "type": "wait",
        "seconds": 20,
        "description": "等待界面初始化和首轮日志输出"
      }
    ],
    "uiAutomation": {
      "windowTitlePattern": "Ruiyan",
      "postLaunchDelaySeconds": 3,
      "actions": [
        {
          "type": "activate_window",
          "windowTitlePattern": "Ruiyan"
        },
        {
          "type": "wait",
          "seconds": 1
        },
        {
          "type": "click_control",
          "windowTitlePattern": "Ruiyan",
          "controlName": "登录",
          "controlType": "Button",
          "enabled": false
        }
      ]
    }
  },
  "trace": {
    "directoryName": "_codex_trace",
    "maxAttempts": 3,
    "saveBeforeAfter": true
  },
  "repair": {
    "enableAutoFix": true,
    "allowedFixes": [
      "rerun-qmake",
      "ensure-output-directory",
      "refresh-translations"
    ],
    "errorRules": [
      {
        "id": "qt-generated-file-missing",
        "pattern": "Cannot open include file: 'ui_",
        "category": "qt-generated-file-missing",
        "autoFix": "rerun-qmake"
      },
      {
        "id": "qt-moc-symbol-missing",
        "pattern": "unresolved external symbol.*metaObject",
        "category": "qt-moc-symbol-missing",
        "autoFix": "rerun-qmake"
      },
      {
        "id": "link-output-path-missing",
        "pattern": "LNK1104",
        "category": "link-output-path-missing",
        "autoFix": "ensure-output-directory"
      },
      {
        "id": "translation-output-missing",
        "pattern": "lrelease error",
        "category": "translation-output-missing",
        "autoFix": "refresh-translations"
      },
      {
        "id": "toolset-missing",
        "pattern": "MSB8020",
        "category": "toolset-missing",
        "autoFix": ""
      },
      {
        "id": "msbuild-filetracker-failure",
        "pattern": "Microsoft\\.Build\\.Utilities\\.FileTracker",
        "category": "msbuild-filetracker-failure",
        "autoFix": ""
      }
    ]
  },
  "report": {
    "reportFileName": "build-report.md",
    "jsonReportFileName": "build-report.json",
    "qmManifestFileName": "qm-manifest.json"
  }
}
